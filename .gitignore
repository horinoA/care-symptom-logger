# すべてのフォルダ階層にある .env を無視
**/.env

# すべてのフォルダ階層にあるローカル・テスト用設定ファイルを無視
**/application-test.properties
**/application-local.properties

# Mac特有のゴミファイル（全階層）
**/.DS_Store

# DockerのPostgreSQLデータ永続化ディレクトリ（Composeの定義に合わせて要調整）
**/pg_data/
**/db_data/

# Docker data volumes (Local DB & GUI settings)
**/pgadmin_data/

# Compiled class file
*.class

# Log file
*.log

# Package Files #
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# virtual machine crash logs
hs_err_pid*
replay_pid*

# Gradle
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar
!**/src/main/**/build/
!**/src/test/**/build/

### STS / Eclipse ###
.apt_generated
.classpath
.factorypath
.project
.settings/
.springBeans
.sts4-cache
bin/
!**/src/main/**/bin/
!**/src/test/**/bin/

### VS Code ###
.vscode/

# テスト出力などのCSVファイルを無視
*.csv